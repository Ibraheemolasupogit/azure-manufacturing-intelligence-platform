        "movement_status": "string",
        "movement_timestamp": "timestamp",
        "movement_type": "string",
        "operator_or_automated_system_id": "string",
        "quantity": "integer",
        "reference_order": "string",
        "source_location": "string",
        "warehouse_id": "string"
      },
      "dataset_name": "warehouse_movements",
      "fields": [
        "movement_id",
        "movement_timestamp",
        "warehouse_id",
        "source_location",
        "destination_location",
        "item_id",
        "quantity",
        "movement_type",
        "movement_status",
        "reference_order",
        "operator_or_automated_system_id"
      ],
      "file_format": "csv",
      "filename": "warehouse_movements.csv",
      "invariants": [
        "quantity > 0"
      ],
      "logical_owner": "warehouse",
      "nullable_fields": [],
      "primary_key": [
        "movement_id"
      ],
      "relationships": {
        "item_id": "catalog.products or catalog.materials",
        "reference_order": "synthetic source reference",
        "warehouse_id": "catalog.warehouses"
      },
      "schema_version": "1.0.0",
      "synthetic_data_classification": "synthetic_portfolio_sample",
      "timestamp_fields": [
        "movement_timestamp"
      ],
      "units": {}
    }
  },
  "schema_version": "1.0.0",
  "synthetic_data_only": true
}
